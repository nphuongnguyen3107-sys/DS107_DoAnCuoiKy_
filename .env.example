# Cấu hình API Key cho mô hình ngôn ngữ lớn (LLM)
# HƯỚNG DẪN: Sao chép file này thành file `.env` và điền thông tin API Key của bạn.
# LƯU Ý: Không chia sẻ file `.env` thực tế lên GitHub.

# 1. Nếu dùng DeepSeek (Model: deepseek-chat)
# DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 2. Nếu dùng OpenAI (Model: gpt-4o-mini)
# OPENAI_API_KEY=your-openai-api-key-here

# 3. Nếu dùng Google Gemini (Model: gemini-2.5-flash-lite)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# Các key backup của Gemini (nếu có để xoay vòng tránh giới hạn băng thông)
GEMINI_API_KEY_BACKUP_1=
GEMINI_API_KEY_BACKUP_2=
